# Application environment
# Set to 'production' on the live server, 'local' for development
APP_ENV=production

# Timezone (IANA tz database name)
APP_TIMEZONE=Asia/Bangkok

# Database connection
# DO NOT commit real credentials to version control
# Use a dedicated non-root DB user with least-privilege permissions in production
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=dci_sis
DB_USER=dci_app
DB_PASS=
